{
  "prompting": {
    "prompt_templates": [
      "{subject}, {scene}, {lighting}, {style}, dataset sample"
    ],
    "variant_dimensions": {
      "subject": ["target object"],
      "scene": ["studio", "outdoor", "indoor"],
      "lighting": ["soft light", "hard side light"],
      "style": ["photorealistic", "documentary"]
    },
    "max_unique_prompts": 5000
  },
  "preview": {
    "images_per_provider": 8
  },
  "full": {
    "images_per_provider": 200
  },
  "providers": [
    {
      "name": "qwen_image_local",
      "enabled": true,
      "command": "python /ABS/PATH/TO/qwen_generate.py --prompt \"{prompt}\" --output \"{output}\"",
      "output_ext": "png",
      "allow_placeholder": false
    },
    {
      "name": "nano_banana",
      "enabled": false,
      "command": "python /ABS/PATH/TO/nano_banana_client.py --prompt \"{prompt}\" --output \"{output}\"",
      "output_ext": "png",
      "allow_placeholder": false
    },
    {
      "name": "gpt_image",
      "enabled": false,
      "command": "python /ABS/PATH/TO/gpt_image_client.py --prompt \"{prompt}\" --output \"{output}\"",
      "output_ext": "png",
      "allow_placeholder": false
    }
  ],
  "refinement": {
    "primary_refine_command": ""
  }
}
